APP_HOST=food.crenel.uk
APP_TIMEZONE=Europe/London
ADDR=:8080
SECURE_COOKIES=true

POSTGRES_DB=foodtrack
POSTGRES_USER=foodtrack
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgres://foodtrack:change-this-postgres-password@db:5432/foodtrack?sslmode=disable

# Get this from https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=replace-with-your-usda-key

# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-64-character-random-hex-string
